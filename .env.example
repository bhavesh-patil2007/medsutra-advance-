# Gemini: Used by prescription analysis and grounded RAG responses.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-3.5-flash"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# Required in production for encrypted local records and signed HttpOnly sessions.
DATA_ENCRYPTION_KEY="GENERATE_A_LONG_RANDOM_SECRET"
AUTH_SESSION_SECRET="GENERATE_A_DIFFERENT_LONG_RANDOM_SECRET"
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI=""

# Optional managed RAG vector store. Without Qdrant, MedSutra uses its included trusted safety knowledge fallback.
QDRANT_URL=""
QDRANT_API_KEY=""
QDRANT_COLLECTION="medsutra_knowledge"

# Optional consent-based patient memory and partner integrations.
MEM0_API_KEY=""
MEM0_BASE_URL="https://api.mem0.ai"
GNANI_API_KEY=""
GNANI_BASE_URL="https://api.vachana.ai"
SLASHY_API_KEY=""
SLASHY_BASE_URL=""
GENZDEAL_API_KEY=""
GENZDEAL_BASE_URL=""

# Optional verified support number shown in the app.
VITE_SUPPORT_PHONE="104"

# GOOGLE_MAPS_API_KEY: Required for Nearby Pharmacy Finder
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# APP_URL: The URL where this applet is hosted
APP_URL="MY_APP_URL"
