    "express": "^4.21.2",
    "fuse.js": "^7.4.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.62.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.7.13",
    "autoprefixer": "^10.4.21",
