{
  "name": "rxbridge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx server.ts",
    "build": "vite build",
    "start": "NODE_ENV=production node dist-server/server.js",
